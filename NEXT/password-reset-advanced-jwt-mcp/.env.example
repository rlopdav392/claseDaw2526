# Copia a .env y rellena con tus valores (Next.js no carga .env.example).
# Supabase: Project Settings → Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# JWT de sesión (cookie httpOnly); mínimo 32 caracteres
AUTH_SESSION_SECRET="cambia-esto-por-un-secreto-largo-de-al-menos-32-chars"

# JWT de enlace de reset (solo en URL); mínimo 8 caracteres
PASSWORD_RESET_JWT_SECRET="cambia-esto-por-un-secreto-para-reset-jwt"

# URL pública de la app (enlaces en emails de reset)
APP_URL="http://localhost:3000"

# Resend (emails) — https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="onboarding@resend.dev"

# Inngest — sin cuenta Cloud: Dev Server local (UI en http://localhost:8288)
# Pon INNGEST_DEV=1 y en otra terminal ejecuta: npm run inngest:dev
# (Next en :3000 + inngest-cli en :8288). No verás eventos en app.inngest.com.
INNGEST_DEV=1
#
# Solo si usas Inngest Cloud en producción: claves en app.inngest.com → Manage → Keys.
# Con INNGEST_DEV=1 no necesitas INNGEST_EVENT_KEY para desarrollo local.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""
